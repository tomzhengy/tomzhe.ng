{
	"ignore": {
		"tags": ["design"],
		"rules": [
			"react-doctor/no-tiny-text",
			"react/no-danger",
			"react-doctor/no-inline-exhaustive-style",
			"react-doctor/no-giant-component",
			"react-doctor/no-wide-letter-spacing",
			"react-doctor/no-layout-transition-inline",
			"react-doctor/no-long-transition-duration",
			"react-doctor/no-pure-black-background",
			"react-doctor/no-z-index-9999",
			"react-doctor/design-no-redundant-size-axes"
		],
		"overrides": [
			{
				"files": [
					"functions/**",
					"scripts/whoop-auth.ts",
					"scripts/withings-auth.ts",
					"scripts/withings-probe.ts",
					"scripts/withings-steps-today.ts"
				],
				"rules": ["knip/files"]
			},
			{
				"files": ["app/components/photography/MosaicGrid.tsx"],
				"rules": [
					"react-doctor/prefer-useReducer",
					"react-doctor/rendering-hydration-mismatch-time",
					"react-doctor/js-batch-dom-css",
					"react-doctor/nextjs-no-img-element"
				]
			},
			{
				"files": ["app/components/sections/LastVisitorProvider.tsx"],
				"rules": ["react-doctor/no-fetch-in-effect"]
			},
			{
				"files": ["scripts/**"],
				"rules": ["react-doctor/js-set-map-lookups"]
			},
			{
				"files": [
					"app/lib/whoop.ts",
					"app/lib/withings.ts",
					"app/components/photography/DevUploadModal.tsx"
				],
				"rules": ["react-doctor/async-await-in-loop"]
			}
		]
	}
}
