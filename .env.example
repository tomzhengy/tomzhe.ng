# supabase (public visitor tracker + suggestion box)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# cloudflare r2 (photo storage, dev-only mutation paths)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=

# whoop — personal health dashboard
# register an app at https://developer.whoop.com
# WHOOP_REFRESH_TOKEN is produced by `bun run scripts/whoop-auth.ts`
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REFRESH_TOKEN=
WHOOP_OAUTH_REDIRECT_URI=http://localhost:3000/whoop-callback

# openrouter — small model for varied dashboard copy
# get a key at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
